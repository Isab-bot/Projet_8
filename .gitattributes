# ===========================================
# Gestion des fins de ligne pour cohérence multi-OS
# Évite les conflits CRLF/LF entre Windows, Linux et macOS
# Critique pour Docker (conteneurs Linux) et CI/CD
# ===========================================

# Par défaut : auto-detect texte vs binaire, et forcer LF
* text=auto eol=lf

# === Fichiers spécifiques Windows (forcer CRLF) ===
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# === Fichiers spécifiques Linux/Docker (forcer LF) ===
*.sh text eol=lf
Dockerfile text eol=lf
*.dockerfile text eol=lf

# === Fichiers de configuration (LF) ===
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.py text eol=lf
*.env* text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# === Fichiers binaires (pas de conversion) ===
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary

# === Modèles ML (binaires) ===
*.pkl binary
*.joblib binary
*.h5 binary
*.bin binary
*.onnx binary
*.parquet binary

# === Données ===
*.csv text eol=lf
