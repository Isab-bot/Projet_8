# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/

# === Environnements virtuels ===
.venv/
venv/
env/
ENV/

# === UV ===
# uv.lock est versionné (bonne pratique reproductibilité)

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# === Tests & Coverage ===
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# === Données (volumineuses, non versionnées) ===
data/raw/
data/processed/
data/interim/
*.csv.gz
*.parquet
# Bases SQLite locales (créées en runtime, jamais versionnées)
data/predictions.db
data/*.db

# Exceptions : fichiers versionnés malgré les règles ci-dessus
!data/samples/
!data/reference_data.parquet

# === Modèles volumineux ===
# On versionne xgboost_champion.pkl si < 100MB
# Sinon utiliser Git LFS
models/*.h5
models/*.bin
models/checkpoints/

# === Secrets & config locale ===
.env
.env.local
.env.*.local
*.key
*.pem
secrets/

# === Logs & runtime ===
*.log
logs/
*.pid


# === MLflow (si jamais utilisé en local) ===
mlruns/
mlflow.db

# === Streamlit ===
.streamlit/secrets.toml

# === OS ===
Thumbs.db
desktop.ini

# === Jupyter ===
.ipynb_checkpoints/
*.ipynb_checkpoints
