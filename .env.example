# ===========================================
# Variables d'environnement - Projet 8
# Copier ce fichier en .env et remplir les valeurs
# ===========================================

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# === Modèle ===
MODEL_PATH=models/xgboost_champion.pkl
FEATURE_NAMES_PATH=models/feature_names.json
PREDICTION_THRESHOLD=0.5

# === Base de données ===
# Si non définie : fallback SQLite automatique (sqlite:///./credit_scoring.db)
# En local (docker-compose) : PostgreSQL via Docker
# En CI/CD et sur Hugging Face Spaces : non définie → SQLite
DATABASE_URL=postgresql://credit_user:credit_pass@localhost:5432/credit_scoring

# === Monitoring ===
REFERENCE_DATA_PATH=models/reference_data.csv
DRIFT_THRESHOLD=0.5

# === Hugging Face (pour CI/CD) ===
# Définir ces variables dans les secrets GitHub Actions, pas en local
# HF_TOKEN=
# HF_SPACE_NAME=
