# ===========================================
# Variables d'environnement - Projet 8
# Copier ce fichier en .env et remplir les valeurs
# ===========================================

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# === Modèle ===
MODEL_PATH=models/xgboost_champion.pkl
FEATURE_NAMES_PATH=models/feature_names.json
PREDICTION_THRESHOLD=0.5

# === Base de données ===
# Stratégie : Postgres (Docker local) en dev, SQLite en fallback CI/HF Spaces.
# - Si DATABASE_URL est définie : SQLAlchemy l'utilise telle quelle.
# - Si non définie : fallback automatique vers sqlite:///./data/predictions.db
#
# Postgres (local Docker, exemple — décommenter et adapter le mot de passe) :
# DATABASE_URL=postgresql+psycopg://credit_user:credit_pass@localhost:5432/credit_scoring
#
# SQLite explicite (rarement utile, le fallback s'en charge) :
# DATABASE_URL=sqlite:///./data/predictions.db
DATABASE_URL=postgresql+psycopg://credit_user:credit_pass@localhost:5432/credit_scoring

# === Monitoring ===
REFERENCE_DATA_PATH=models/reference_data.csv
DRIFT_THRESHOLD=0.5

# === Hugging Face (pour CI/CD) ===
# Définir ces variables dans les secrets GitHub Actions, pas en local
# HF_TOKEN=
# HF_SPACE_NAME=
