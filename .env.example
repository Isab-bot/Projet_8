# ===========================================
# Variables d'environnement - Projet 8
# Copier ce fichier en .env et remplir les valeurs
# ===========================================

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# === Modèle ===
MODEL_PATH=models/xgboost_champion.pkl

# === Base de données ===
# Stratégie : Postgres (Docker via docker-compose) en dev, SQLite en fallback CI/HF Spaces.
# - Si DATABASE_URL est définie : SQLAlchemy l'utilise telle quelle.
# - Si non définie : fallback automatique vers sqlite:///./data/predictions.db
#
# Postgres local via docker-compose :
#   - Service exposé sur localhost:5433 (port mappé depuis le 5432 interne du container)
#   - Credentials définis dans docker/docker-compose.yml
#   - Démarrage : docker compose -f docker/docker-compose.yml up -d
#
# SQLite explicite (rarement utile, le fallback s'en charge) :
# DATABASE_URL=sqlite:///./data/predictions.db
DATABASE_URL=postgresql+psycopg://credit_user:credit_pass@localhost:5433/credit_scoring

# === Monitoring ===
REFERENCE_DATA_PATH=models/reference_data.csv
DRIFT_THRESHOLD=0.5



# === Hugging Face (pour CI/CD) ===
# Définir ces variables dans les secrets GitHub Actions, pas en local
# HF_TOKEN=
# HF_SPACE_NAME=
